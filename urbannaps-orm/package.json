{
   "name": "@UrbanNaps/urbannaps-orm",
   "version": "0.0.34",
   "description": "ORM and RDS migration repository of UrbanNaps",
   "author": "Ravi Desai<desai.ravi1101@gmail.com>",
   "type": "commonjs",
   "main": "build/index.js",
   "types": "build/index.d.ts",
   "files": [
      "build/**/*"
   ],
   "devDependencies": {
      "@types/node": "^16.11.10",
      "dotenv": "^16.3.1",
      "fs-extra": "^11.2.0",
      "readdirp": "^3.6.0",
      "ts-node": "10.7.0",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "mysql": "^2.14.1",
      "reflect-metadata": "^0.1.13",
      "typeorm": "0.3.17"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/UrbanNaps/urbannaps-orm.git"
   },
   "publishConfig": {
      "registry": "https://npm.pkg.github.com/UrbanNaps"
   },
   "homepage": "https://github.com/UrbanNaps/urbannaps-orm/blob/main/README.md",
   "scripts": {
      "build": "tsc",
      "test": "ts-node test/index.ts",
      "typeorm": "typeorm-ts-node-commonjs",
      "prepare": "npm run build",
      "generate:index": "node utils/generate-index.js",
      "migrate": "npx typeorm-ts-node-commonjs migration:run -d ./test/migration-data-source.ts"
   }
}
